        <SQLTask:SqlTaskData
          SQLTask:Connection="{78FD8C46-DA97-40AC-A8F6-74ECC79C6FE7}"
          SQLTask:SqlStatementSource="SELECT ISNULL(&#xA;    MAX(status_date),&#xA;    (SELECT last_load_date FROM ETL_Watermark WHERE table_name = 'order_history')&#xA;)&#xA;FROM order_history&#xA;WHERE status_date &gt; (&#xA;    SELECT last_load_date FROM ETL_Watermark WHERE table_name = 'order_history'&#xA;)"
