                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    oh.history_id,
    oh.order_id,
    oh.status_id,
    oh.status_date,
    co.customer_id,
	co.shipping_method_id,
    os.status_value
FROM gravity_books.dbo.order_history oh
JOIN gravity_books.dbo.order_line o 
    ON oh.order_id = o.order_id
Join gravity_books.dbo.cust_order co 
	ON o.order_id = co.order_id
JOIN gravity_books.dbo.order_status os 
    ON oh.status_id = os.status_id</property>
